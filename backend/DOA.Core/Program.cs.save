`çusing DOA.Core.Models;
using DOA.Core.Services;

var builder = WebApplication.CreateBuilder(args);

// сохранение сервисов
builder.Services.AddSingleton<ConfigService>();
builder.Services.AddSingleton<PathService>();
builder.Services.AddSingleton<NoteService>();
builder.Services.AddSingleton<ShellService>();
builder.Services.AddSingleton<SystemService>();
builder.Services.AddSingleton<CommandDispatcher>();

var app = builder.Build();

// загрузка конфиг
var configService = app.Services.GetRequiredService<ConfigService>();
var cfg = configService.Load<AppConfig>()
          ?? throw new Exception("Failed to load DOA config.");

Console.WriteLine($"[DOA CONFIG] Loaded theme: {cfg.Theme}");

// UI на URL
app.MapGet("/", () =>
{
    var html = """
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>DOA: Duck Of Apocalypse — Terminal</title>
  <style>
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      background: #050505;
      color: #00ff66;
      font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    }
    .container {
      display: flex;
      flex-direction: column;
      height: 100%;
      padding: 16px;
      box-sizing: border-box;
    }
    .header {
      font-size: 18px;
      margin-bottom: 8px;
      color: #00ff99;
    }
    .subheader {
      font-size: 12px;
      color: #00aa55;
      margin-bottom: 8px;
    }
    #console {
      flex: 1;
      background: #020202;
      border: 1px solid #00aa55;
      padding: 8px;
      overflow-y: auto;
      white-space: pre-wrap;
      font-size: 13px;
    }
    .input-row {
      margin-top: 8px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .prompt {
      color: #00ff66;
      font-size: 14px;
    }
    #commandInput {
      flex: 1;
      background: #000000;
      border: 1px solid #00aa55;
      color: #00ff66;
      padding: 6px 8px;
      font-size: 14px;
      outline: none;
    }
    #commandInput:focus {
      border-color: #00ff99;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">DOA: Duck Of Apocalypse — Neural Terminal Interface</div>
    <div class="subheader">Type a command (example: <code>system.info</code>, <code>note.new Test Hello</code>, <code>note.list</code>)</div>

    <div id="console"></div>

    <div class="input-row">
      <span class="prompt">DOA::</span>
      <input id="commandInput" type="text" autocomplete="off" />
    </div>
  </div>

  <script>
    const consoleEl = document.getElementById('console');
    const inputEl = document.getElementById('commandInput');

    function printLine(text) {
      const line = document.createElement('div');
      line.textContent = text;
      consoleEl.appendChild(line);
      consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    async function sendCommand(raw) {
        const trimmed = raw.trim();
        if (!trimmed) return;

        printLine('> ' + trimmed);

        try {
            const res = await fetch('/command', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ raw: trimmed })
            });

            if (!res.ok) {
            printLine('[ERROR] HTTP ' + res.status);
            return;
            }

            const json = await res.json();
            printLine('[' + json.status.toUpperCase() + '] ' + json.message);

        if (json.data) {
        // Если это результат shell-команды
        if (json.data.stdout !== undefined || json.data.stderr !== undefined) {
            if (json.data.stdout) {
            printLine(json.data.stdout.trimEnd());
            }
            if (json.data.stderr) {
            printLine(json.data.stderr.trimEnd());
            }
        }
        // Если это список (например, note.list)
        else if (Array.isArray(json.data)) {
            json.data.forEach(x => printLine('- ' + x));
        }
        // Если это заметка (title + content)
        else if (json.data.content && json.data.title) {
            printLine('# ' + json.data.title);
            printLine(json.data.content);
        }
        // fallback — на всякий случай
        else {
            const pretty = JSON.stringify(json.data, null, 2);
            printLine(pretty);
        }
        }
        
        } catch (err) {
            printLine('[ERROR] ' + err);
        }
    }

    inputEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const value = inputEl.value;
        inputEl.value = '';
        sendCommand(value);
      }
    });

    // Приветственное сообщение
    printLine('DOA Core UI loaded. Use commands like:');
    printLine('  system.info');
    printLine('  system.time');
    printLine('  note.new TestNote Hello');
    printLine('  note.list');
    printLine('----------------------------------------');
    inputEl.focus();
  </script>
</body>
</html>
""";

    return Results.Content(html, "text/html");
});

// основной endpoint для команд
app.MapPost("/command", (CommandRequest request, CommandDispatcher dispatcher) =>
{
    var response = dispatcher.Dispatch(request);
    return Results.Json(response);
});

// запуск
app.Run("http://localhost:7070");
